# chezmoi bootstrap config
# Generated on chezmoi init — stored at ~/.config/chezmoi/chezmoi.toml

encryption = "age"

[age]
    identity = "~/.config/sops/age/keys.txt"

[bitwarden]
    unlock = "auto"

[data]
    name  = "{{ promptStringOnce . "name"  "Full name (for git config)" }}"
    email = "{{ promptStringOnce . "email" "Email (for git config)" }}"
