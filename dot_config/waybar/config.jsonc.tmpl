// -*- mode: jsonc -*-
{{- $m := index .machines .chezmoi.hostname }}
{
    "position": "top",
    "height": 48,
    "spacing": 0,
    "reload_style_on_change": true,
    // Module Layout: Workspaces | Window Title | MPRIS | DateTime | System Info | Tray
    "modules-left": [
        {{ if eq $m.wm "sway" }}"sway/workspaces"{{ else }}"hyprland/workspaces"{{ end }}
    ],
    "modules-center": [
        {{ if eq $m.wm "sway" }}"sway/window"{{ else }}"hyprland/window"{{ end }}
    ],
    "modules-right": [
        "mpris",
        "clock",
        "network",
        "custom/vpn",
        "privacy",
        "pulseaudio",
        "battery",
        "custom/water",
        "idle_inhibitor",
        "group/tray-expander"
    ],
    "battery": {
        "bat": "BAT0",
        "interval": 20,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{icon}󱐋 {capacity}%",
        "format-icons": [
            "󰂎",
            "󰁺",
            "󰁻",
            "󰁼",
            "󰁽",
            "󰁾",
            "󰁿",
            "󰂀",
            "󰂁",
            "󰂂",
            "󰁹"
        ],
        "tooltip": true,
        "tooltip-format": "Time: {time} left\nCapacity: {health}%\n{power} watts"
    },
    "mpris": {
        "format": "{status_icon} {artist} - {title}",
        "format-paused": "{status_icon} <i>{artist} - {title}</i>",
        "format-stopped": "",
        "tooltip-format": "{player}: {artist} - {title} [{position}/{length}]",
        "status-icons": {
            "playing": "󰐊",
            "paused": "󰏤",
            "stopped": "󰓛"
        },
        "player-icons": {
            "default": "🎵"
        },
        "title-len": 20,
        "artist-len": 20,
        "album-len": 20
    },
    // Merged DateTime Module - Shows both time and date with calendar on hover
    "clock": {
        "format": "{:%H:%M  %a %d %b}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "mullvad status | grep -q 'Connected' && echo '{\"text\":\"󱚿\",\"class\":\"connected\"}' || echo '{\"text\":\"󱛀\",\"class\":\"disconnected\"}'",
        "return-type": "json",
        "interval": 5,
        "tooltip-format": "VPN Status\nClick to connect | Right-click to disconnect",
        "on-click": "mullvad connect",
        "on-click-right": "mullvad disconnect"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": "󰾪"
        },
        "tooltip-format-activated": "Idle inhibitor: Active",
        "tooltip-format-deactivated": "Idle inhibitor: Inactive"
    },
    {{ if eq $m.wm "sway" }}
    "sway/workspaces": {
        "format": "{icon}"
    },
    {{ else }}
    "hyprland/workspaces": {
        "format": "{icon}",
        "move-to-monitor": true
    },
    {{ end }}
    "network": {
        "format-wifi": "󰤟 {essid} ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "format-ethernet": "󰈀 ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "interval": 3,
        "format-linked": "{ifname} (No IP)",
        "format": "",
        "format-disconnected": "󰤟",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "tooltip-format": "{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-wifi": "󰤟 {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}",
        "max-length": 50
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "󰂰  {volume}%",
        "format-bluetooth-muted": "󰂰󰖁 ",
        "format-muted": "󰖁 ",
        "format-source": " micrófono",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "󰋋",
            "headset": "󰋋",
            "default": ["󰕾  ", "󰖀  ", "󰕾  "], // low, medium, high
            "bluetooth": "󰂰",
            "phone": "󰂰"
        },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\nClick to open mixer"
    },
    "tray": {
        "spacing": 12,
        "icon-size": 18
    },
    "custom/tray-expand-icon": {
        "format": " ",
        "tooltip": false
    },
    "privacy": {
        "icon-spacing": 6,
        "icon-size": 16,
        "transition-duration": 250,
        "modules": [
            { "type": "screenshare", "icon-name": "screen-shared-symbolic", "tooltip": true },
            { "type": "audio-in", "icon-name": "audio-input-microphone-symbolic", "tooltip": true }
        ]
    },
    "group/tray-expander": {
        "drawer": {
            "transition-duration": 325
        },
        "modules": [
            "custom/tray-expand-icon",
            "tray"
        ],
        "orientation": "inherit"
    },
    {{ if eq $m.wm "sway" }}
    "sway/window": {
        "format": "{}",
        "max-length": 50,
        "tooltip": false
    },
    {{ else }}
    "hyprland/window": {
        "format": "{}",
        "empty-format": "Desktop",
        "separate-outputs": true,
        "max-length": 50,
        "tooltip": false
    },
    {{ end }}
    "custom/water": {
        "format": "{}",
        "exec": "~/.local/bin/water.py",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "on-click": "~/.local/bin/water.py --drank"
    }
}
