// -*- mode: jsonc -*-
{
    "position": "top",
    "height": 48,
    "spacing": 0,
    "reload_style_on_change": true,
    // Module Layout: Workspaces | Window Title | DateTime | System Info | Tray
    "modules-left": [
        {{ if eq .chezmoi.hostname "emin-probook" }}"sway/workspaces"{{ else }}"hyprland/workspaces"{{ end }}
    ],
    "modules-center": [
        {{ if eq .chezmoi.hostname "emin-probook" }}"sway/window"{{ else }}"hyprland/window"{{ end }}
    ],
    "modules-right": [
        "clock",
        "network",
        "custom/vpn",
        "pulseaudio",
        "battery",
        "idle_inhibitor",
        "group/tray-expander"
    ],
    "battery": {
        "bat": "BAT0",
        "interval": 20,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{icon}σ±ê΄ {capacity}%",
        "format-icons": [
            "σΑ²é",
            "σΑ¹Κ",
            "σΑ¹Μ",
            "σΑ¹Φ",
            "σΑ¹Ϋ",
            "σΑ¹Ψ",
            "σΑ¹Ω",
            "σΑ²Ä",
            "σΑ²¹",
            "σΑ²²",
            "σΑ¹Ι"
        ],
        "tooltip": true,
        "tooltip-format": "Time: {time} left\nCapacity: {health}%\n{power} watts"
    },
    // Merged DateTime Module - Shows both time and date with calendar on hover
    "clock": {
        "format": "{:%H:%M  %a %d %b}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "mullvad status | grep -q 'Connected' && echo '{\"text\":\"σ±öΩ\",\"class\":\"connected\"}' || echo '{\"text\":\"σ±¦Ä\",\"class\":\"disconnected\"}'",
        "return-type": "json",
        "interval": 5,
        "tooltip-format": "VPN Status\nClick to connect | Right-click to disconnect",
        "on-click": "mullvad connect",
        "on-click-right": "mullvad disconnect"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": "σΑΨΣ"
        },
        "tooltip-format-activated": "Idle inhibitor: Active",
        "tooltip-format-deactivated": "Idle inhibitor: Inactive"
    },
    {{ if eq .chezmoi.hostname "emin-probook" }}
    "sway/workspaces": {
        "format": "{icon}",
        "on-click": "focus"
    },
    {{ else }}
    "hyprland/workspaces": {
        "format": "{icon}",
        "move-to-monitor": true,
        "on-click": "activate"
    },
    {{ end }}
    "network": {
        "format-wifi": "σΑΛü {essid} βÜ™{bandwidthDownBits} βÜë{bandwidthUpBits}",
        "format-ethernet": "σΑàÄ βÜ™{bandwidthDownBits} βÜë{bandwidthUpBits}",
        "interval": 3,
        "format-linked": "{ifname} (No IP)",
        "format": "",
        "format-disconnected": "σΑΛü",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "tooltip-format": "βÜë {bandwidthUpBits}  βÜ™ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-wifi": "σΑΛü {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nβÜë {bandwidthUpBits}  βÜ™ {bandwidthDownBits}",
        "max-length": 50
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "σΑ²Α  {volume}%",
        "format-bluetooth-muted": "σΑ²ΑσΑ•¹ ",
        "format-muted": "σΑ•¹ ",
        "format-source": " micrΟ≥fono",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "headset": "σΑ΄΄",
            "default": ["σΑïΨ  ", "σΑ•Ä  ", "σΑïΨ  "], // low, medium, high
            "bluetooth": "σΑ²Α",
            "phone": "σΑ²Α"
        },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\nClick to open mixer"
    },
    "tray": {
        "spacing": 12,
        "icon-size": 18
    },
    "custom/tray-expand-icon": {
        "format": " ",
        "oltip": false
    },
    "group/tray-expander": {
        "drawer": {
            "transition-duration": 325
        },
        "modules": [
            "custom/tray-expand-icon",
            "tray"
        ],
        "orientation": "inherit"
    },
    {{ if eq .chezmoi.hostname "emin-probook" }}
    "sway/window": {
        "format": "{}",
        "max-length": 50,
        "tooltip": false
    },
    {{ else }}
    "hyprland/window": {
        "format": "{}",
        "empty-format": "Desktop",
        "separate-outputs": true,
        "max-length": 50,
        "tooltip": false
    },
    {{ end }}
    "custom/hiddenwindow": {
        "exec": "waybar-scripts check_special_workspace",
        "tooltip": true,
        "signal": 3
    }
}
