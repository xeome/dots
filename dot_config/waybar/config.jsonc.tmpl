// -*- mode: jsonc -*-
{
    "position": "top",
    "height": 48,
    "spacing": 0,
    "reload_style_on_change": true,
    // Module Layout: Workspaces | Window Title | MPRIS | DateTime | System Info | Tray
    "modules-left": [
        {{ if eq .chezmoi.hostname "emin-probook" }}"sway/workspaces"{{ else }}"hyprland/workspaces"{{ end }}
    ],
    "modules-center": [
        {{ if eq .chezmoi.hostname "emin-probook" }}"sway/window"{{ else }}"hyprland/window"{{ end }}
    ],
    "modules-right": [
        "mpris",
        "clock",
        "network",
        "custom/vpn",
        "pulseaudio",
        "battery",
        "idle_inhibitor",
        "group/tray-expander"
    ],
    "battery": {
        "bat": "BAT0",
        "interval": 20,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{icon}َ±گ‹ {capacity}%",
        "format-icons": [
            "َ°‚ژ",
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "tooltip": true,
        "tooltip-format": "Time: {time} left\nCapacity: {health}%\n{power} watts"
    },
    "mpris": {
        "format": "{status_icon} {artist} - {title}",
        "format-paused": "{status_icon} <i>{artist} - {title}</i>",
        "format-stopped": "",
        "tooltip-format": "{player}: {artist} - {title} [{position}/{length}]",
        "status-icons": {
            "playing": "َ°گٹ",
            "paused": "َ°ڈ¤",
            "stopped": "َ°“›"
        },
        "player-icons": {
            "default": "ًںژµ"
        },
        "title-len": 20,
        "artist-len": 20,
        "album-len": 20
    },
    // Merged DateTime Module - Shows both time and date with calendar on hover
    "clock": {
        "format": "{:%H:%M  %a %d %b}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "mullvad status | grep -q 'Connected' && echo '{\"text\":\"َ±ڑ؟\",\"class\":\"connected\"}' || echo '{\"text\":\"َ±›€\",\"class\":\"disconnected\"}'",
        "return-type": "json",
        "interval": 5,
        "tooltip-format": "VPN Status\nClick to connect | Right-click to disconnect",
        "on-click": "mullvad connect",
        "on-click-right": "mullvad disconnect"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": "َ°¾ھ"
        },
        "tooltip-format-activated": "Idle inhibitor: Active",
        "tooltip-format-deactivated": "Idle inhibitor: Inactive"
    },
    {{ if eq .chezmoi.hostname "emin-probook" }}
    "sway/workspaces": {
        "format": "{icon}",
        "on-click": "focus"
    },
    {{ else }}
    "hyprland/workspaces": {
        "format": "{icon}",
        "move-to-monitor": true,
        "on-click": "activate"
    },
    {{ end }}
    "network": {
        "format-wifi": "َ°¤ں {essid} â†“{bandwidthDownBits} â†‘{bandwidthUpBits}",
        "format-ethernet": "َ°ˆ€ â†“{bandwidthDownBits} â†‘{bandwidthUpBits}",
        "interval": 3,
        "format-linked": "{ifname} (No IP)",
        "format": "",
        "format-disconnected": "َ°¤ں",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "tooltip-format": "â†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-wifi": "َ°¤ں {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nâ†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}",
        "max-length": 50
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "َ°‚°  {volume}%",
        "format-bluetooth-muted": "َ°‚°َ°–پ ",
        "format-muted": "َ°–پ ",
        "format-source": " micrأ³fono",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headset": "َ°‹‹",
            "default": ["َ°•¾  ", "َ°–€  ", "َ°•¾  "], // low, medium, high
            "bluetooth": "َ°‚°",
            "phone": "َ°‚°"
        },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\nClick to open mixer"
    },
    "tray": {
        "spacing": 12,
        "icon-size": 18
    },
    "custom/tray-expand-icon": {
        "format": " ",
        "oltip": false
    },
    "group/tray-expander": {
        "drawer": {
            "transition-duration": 325
        },
        "modules": [
            "custom/tray-expand-icon",
            "tray"
        ],
        "orientation": "inherit"
    },
    {{ if eq .chezmoi.hostname "emin-probook" }}
    "sway/window": {
        "format": "{}",
        "max-length": 50,
        "tooltip": false
    },
    {{ else }}
    "hyprland/window": {
        "format": "{}",
        "empty-format": "Desktop",
        "separate-outputs": true,
        "max-length": 50,
        "tooltip": false
    },
    {{ end }}
    "custom/hiddenwindow": {
        "exec": "waybar-scripts check_special_workspace",
        "tooltip": true,
        "signal": 3
    }
}
