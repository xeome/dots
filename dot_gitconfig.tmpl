[user]
    name       = {{ .name | quote }}
    email      = {{ .email | quote }}
    signingkey = "3E4E41CBA53A8BEB"

[commit]
    gpgsign = true

[core]
    editor     = nvim
    autocrlf   = input
    pager      = delta

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[merge]
    tool = vimdiff

[diff]
    tool = vimdiff

[alias]
    st  = status
    lg  = log --oneline --graph --decorate --all
    co  = checkout
    br  = branch
