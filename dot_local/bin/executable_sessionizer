#!/usr/bin/env bash

SESSIONIZER_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/sessionizer"
RECENT_FILE="$SESSIONIZER_DIR/recent"
mkdir -p "$SESSIONIZER_DIR"

SCAN_DIRS=("$HOME/Sync" "$HOME/.config" "$HOME/work")

add_to_recent() {
    local dir="$1"
    [[ -z "$dir" || ! -d "$dir" ]] && return 1
    if [[ -f "$RECENT_FILE" ]]; then
        grep -q "^${dir}$" "$RECENT_FILE" && return 0
    fi
    echo "$dir" >> "$RECENT_FILE"
}

remove_from_recent() {
    local dir="$1"
    [[ -z "$dir" ]] && return 1
    grep -v "^${dir}$" "$RECENT_FILE" > /tmp/sess_tmp && mv /tmp/sess_tmp "$RECENT_FILE"
}

search_to_add() {
    fd . "${SCAN_DIRS[@]}" --min-depth 1 --max-depth 3 -t d 2>/dev/null | fzf --prompt="Add: " --preview 'ls -la {}'
}

while true; do
    RESULT=$(cat "$RECENT_FILE" 2>/dev/null | fzf \
        --prompt="🚀 Project: " \
        --header="ctrl-a: add | ctrl-d: remove | ctrl-x: search to add | enter: select" \
        --expect=ctrl-a,ctrl-d,ctrl-x,enter \
        --preview 'ls -la {}')

    KEYPressed=$(echo "$RESULT" | head -1)
    TARGET=$(echo "$RESULT" | tail -n +2)

    case "$KEYPressed" in
        ctrl-a)
            [[ -n "$TARGET" ]] && add_to_recent "$TARGET"
            ;;
        ctrl-d)
            [[ -n "$TARGET" ]] && remove_from_recent "$TARGET"
            ;;
        ctrl-x)
            NEW=$(search_to_add)
            [[ -n "$NEW" ]] && add_to_recent "$NEW"
            ;;
        *)
            break
            ;;
    esac
done

[[ -z "$TARGET" ]] && exit 0

SESSION_NAME=$(basename "$TARGET" | tr ' .:' '_')
cd "$TARGET" && exec zellij attach -c "$SESSION_NAME"
